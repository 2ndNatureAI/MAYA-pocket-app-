# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=500
OPENAI_REQUEST_TIMEOUT_MS=30000

# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=your_secret_key_change_in_prod_min_32_chars_required_!!!
JWT_EXPIRY=2h
ADMIN_JWT_EXPIRY=1h

# Admin (pre-hash password with: node -e "console.log(require('bcryptjs').hashSync('password', 10))")
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$...

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_LOGIN_MAX_ATTEMPTS=5
CHAT_RATE_LIMIT_REQUESTS_PER_HOUR=100

# Message validation
MAX_MESSAGE_LENGTH=2000
MAX_CONVERSATION_MESSAGES=50
MAX_TOKENS_PER_REQUEST=2500

# After-hours
AFTER_HOURS_START=18
AFTER_HOURS_END=8
AFTER_HOURS_ENABLED=true

# Features
HUMAN_REVIEW_ENABLED=true
LOG_EXPORT_ENABLED=true

# Cors
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Monitoring
LOG_LEVEL=info
AUDIT_LOG_ENABLED=true
