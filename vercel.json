{
  "$schema": "https://json.schemastore.org/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "installCommand": "npm install --prefix backend && npm install --prefix frontend",
  "devCommand": "npm run dev --prefix backend & npm run dev --prefix frontend",
  "env": [
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "OPENAI_API_KEY",
    "ADMIN_USERNAME",
    "ADMIN_PASSWORD_HASH",
    "JWT_SECRET",
    "NODE_ENV",
    "ALLOWED_ORIGINS"
  ],
  "builds": [
    {
      "src": "backend/server-secure.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/dist",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server-secure.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    },
    {
      "src": "/",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
